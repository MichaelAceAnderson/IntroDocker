# Mot de passe de l'utilisateur root de la base de données
MARIADB_ROOT_PASSWORD=changeme
# Nom de la base de données
MARIADB_DATABASE=mydocker-db
# Nom d'utilisateur de la base de données
MARIADB_USER=mydocker
# Mot de passe de l'utilisateur de la base de données
MARIADB_PASSWORD=mydockerpwd
# Port de la base de données
# Ce port doit correspondre au port EXPOSE dans le Dockerfile et/ou mappé dans docker-compose.yml
DB_PORT=3306
